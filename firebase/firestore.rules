rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the owner can read/write their document, sessions, and weights
    match /users/{userId} {
      // User profile document (stores displayName, weightKg, preferredUnits, etc.)
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Sessions subcollection: owner-only access
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Weights subcollection: owner-only access
      match /weights/{weightId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Machines collection: public read-only
    match /machines/{machineId} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
