*-service-account*.json
*-firebase-adminsdk*.json
serviceAccountKey.json
firebase-service-account.json

# État local Firebase et logs de débogage
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log

# ── OS & éditeurs ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json

# ── Tests & couverture ────────────────────────────────────────────────────────
coverage/
.e2e/
playwright-report/
test-results/

# ── Certificats & clés privées ────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
